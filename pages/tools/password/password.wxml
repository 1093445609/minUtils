<view class="password-container">
  <!-- 密码显示 -->
  <view class="password-section">
    <text class="section-title">生成的密码</text>
    <view class="password-display">
      <text class="password-text">{{generatedPassword}}</text>
      <button class="copy-button" bindtap="copyPassword" wx:if="{{generatedPassword}}">
        <text class="copy-icon">📋</text>
      </button>
    </view>
  </view>

  <!-- 密码设置 -->
  <view class="setting-section">
    <text class="section-title">密码设置</text>
    
    <!-- 密码长度 -->
    <view class="setting-item">
      <text class="setting-label">密码长度: {{passwordLength}}</text>
      <slider min="6" max="20" value="{{passwordLength}}" bindchange="onLengthChange" class="slider" />
    </view>

    <!-- 字符类型 -->
    <view class="setting-item">
      <text class="setting-label">字符类型</text>
      <checkbox-group class="checkbox-group" bindchange="onCheckboxChange">
        <label class="checkbox-item">
          <checkbox value="uppercase" checked="{{includeUppercase}}" />
          <text>大写字母 (A-Z)</text>
        </label>
        <label class="checkbox-item">
          <checkbox value="lowercase" checked="{{includeLowercase}}" />
          <text>小写字母 (a-z)</text>
        </label>
        <label class="checkbox-item">
          <checkbox value="numbers" checked="{{includeNumbers}}" />
          <text>数字 (0-9)</text>
        </label>
        <label class="checkbox-item">
          <checkbox value="symbols" checked="{{includeSymbols}}" />
          <text>特殊字符 (!@#$%^&*)</text>
        </label>
      </checkbox-group>
    </view>
  </view>

  <!-- 生成按钮 -->
  <view class="button-section">
    <button class="generate-button" bindtap="generatePassword" type="primary">生成密码</button>
  </view>

  <!-- 密码强度 -->
  <view class="strength-section" wx:if="{{generatedPassword}}">
    <text class="section-title">密码强度</text>
    <view class="strength-bar">
      <view class="strength-indicator" style="width: {{strengthPercentage}}%; background-color: {{strengthColor}};"></view>
    </view>
    <text class="strength-text">{{strengthLevel}}</text>
  </view>
</view>
.password-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
}

/* 密码显示区域 */
.password-section {
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 15rpx;
}

.password-display {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  border: 2rpx solid #e0e0e0;
}

.password-text {
  flex: 1;
  font-size: 32rpx;
  font-family: monospace;
  color: #333333;
  word-break: break-all;
}

.copy-button {
  width: 60rpx;
  height: 60rpx;
  padding: 0;
  background-color: #007AFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 15rpx;
}

.copy-icon {
  font-size: 32rpx;
  color: #ffffff;
}

/* 设置区域 */
.setting-section {
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

.setting-item {
  margin-bottom: 20rpx;
}

.setting-label {
  display: block;
  font-size: 26rpx;
  font-weight: 500;
  color: #666666;
  margin-bottom: 10rpx;
}

.slider {
  width: 100%;
  margin-bottom: 10rpx;
}

.checkbox-group {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.checkbox-item {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #333333;
}

.checkbox-item checkbox {
  margin-right: 15rpx;
  transform: scale(1.2);
}

/* 按钮区域 */
.button-section {
  margin-bottom: 20rpx;
}

.generate-button {
  width: 100%;
  height: 80rpx;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 8rpx;
}

/* 密码强度区域 */
.strength-section {
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

.strength-bar {
  width: 100%;
  height: 10rpx;
  background-color: #e0e0e0;
  border-radius: 5rpx;
  margin-bottom: 10rpx;
  overflow: hidden;
}

.strength-indicator {
  height: 100%;
  border-radius: 5rpx;
  transition: width 0.3s ease, background-color 0.3s ease;
}

.strength-text {
  display: block;
  font-size: 24rpx;
  color: #666666;
  text-align: right;
}
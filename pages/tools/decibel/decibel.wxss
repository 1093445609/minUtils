.decibel-container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

/* 分贝值显示 */
.display-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #ffffff;
  margin: 20rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.1);
  position: relative;
}

.decibel-value {
  font-size: 120rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 20rpx;
}

.decibel-unit {
  font-size: 40rpx;
  color: #666666;
  margin-bottom: 20rpx;
}

.decibel-level {
  font-size: 32rpx;
  color: #007AFF;
  font-weight: 600;
}

/* 波形模拟 */
.waveform-area {
  height: 200rpx;
  background-color: #ffffff;
  margin: 0 20rpx 20rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
}

.waveform {
  display: flex;
  align-items: flex-end;
  height: 150rpx;
  gap: 5rpx;
}

.wave-bar {
  width: 10rpx;
  border-radius: 5rpx 5rpx 0 0;
  transition: height 0.3s ease;
}

/* 控制区域 */
.control-area {
  background-color: #ffffff;
  border-top-left-radius: 24rpx;
  border-top-right-radius: 24rpx;
  padding: 30rpx 20rpx;
  box-shadow: 0 -4rpx 8rpx rgba(0, 0, 0, 0.05);
}

/* 控制区域 */
.control-section {
  margin-bottom: 30rpx;
}

.test-button {
  width: 100%;
  height: 80rpx;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 8rpx;
}

/* 分贝等级说明 */
.level-guide {
  padding: 20rpx;
  background-color: #f0f7ff;
  border-radius: 8rpx;
}

.guide-title {
  display: block;
  font-size: 26rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 15rpx;
}

.level-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 15rpx;
  margin-bottom: 10rpx;
  border-radius: 6rpx;
  color: #ffffff;
  font-size: 24rpx;
}

.level-item:last-child {
  margin-bottom: 0;
}

.level-range {
  font-weight: 500;
}

.level-desc {
  font-size: 22rpx;
}
<view class="calculator">
  <!-- 表达式显示区域 -->
  <view class="expression-area">
    <view class="expression" wx:if="{{expression}}">{{expression}}</view>
  </view>
  
  <!-- 结果输出区域 -->
  <view class="result-area">
    <view class="result {{display.length > 9 ? 'result-small' : ''}}">{{display}}</view>
  </view>

  <!-- 按钮区域 -->
  <view class="buttons">
    <!-- 第一行 -->
    <view class="row">
      <button class="btn func" bindtap="onTap" data-value="AC">AC</button>
      <button class="btn func" bindtap="onTap" data-value="+/-">±</button>
      <button class="btn func" bindtap="onTap" data-value="%">%</button>
      <button class="btn operator {{activeOperator === '/' ? 'active' : ''}}" bindtap="onTap" data-value="/">÷</button>
    </view>
    <!-- 第二行 -->
    <view class="row">
      <button class="btn number" bindtap="onTap" data-value="7">7</button>
      <button class="btn number" bindtap="onTap" data-value="8">8</button>
      <button class="btn number" bindtap="onTap" data-value="9">9</button>
      <button class="btn operator {{activeOperator === '*' ? 'active' : ''}}" bindtap="onTap" data-value="*">×</button>
    </view>
    <!-- 第三行 -->
    <view class="row">
      <button class="btn number" bindtap="onTap" data-value="4">4</button>
      <button class="btn number" bindtap="onTap" data-value="5">5</button>
      <button class="btn number" bindtap="onTap" data-value="6">6</button>
      <button class="btn operator {{activeOperator === '-' ? 'active' : ''}}" bindtap="onTap" data-value="-">−</button>
    </view>
    <!-- 第四行 -->
    <view class="row">
      <button class="btn number" bindtap="onTap" data-value="1">1</button>
      <button class="btn number" bindtap="onTap" data-value="2">2</button>
      <button class="btn number" bindtap="onTap" data-value="3">3</button>
      <button class="btn operator {{activeOperator === '+' ? 'active' : ''}}" bindtap="onTap" data-value="+">+</button>
    </view>
    <!-- 第五行 -->
    <view class="row">
      <button class="btn number zero" bindtap="onTap" data-value="0">0</button>
      <button class="btn number" bindtap="onTap" data-value=".">.</button>
      <button class="btn equal" bindtap="onEqual">=</button>
    </view>
  </view>
</view>
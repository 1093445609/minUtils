.calculator-container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

/* 模式切换 */
.mode-toggle {
  display: flex;
  background-color: #ffffff;
  margin: 20rpx;
  border-radius: 8rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

.mode-btn {
  flex: 1;
  padding: 20rpx;
  text-align: center;
  font-size: 28rpx;
  color: #666666;
  background-color: #f0f0f0;
  transition: all 0.2s ease;
}

.mode-btn.active {
  background-color: #007AFF;
  color: #ffffff;
}

/* 显示区域 */
.display-area {
  background-color: #ffffff;
  margin: 0 20rpx 20rpx;
  border-radius: 8rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
  text-align: right;
}

.expression {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 10rpx;
  word-break: break-all;
}

.result {
  font-size: 48rpx;
  font-weight: 600;
  color: #333333;
  word-break: break-all;
}

/* 按键区域 */
.keypad {
  flex: 1;
  background-color: #ffffff;
  margin: 0 20rpx 20rpx;
  border-radius: 8rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

/* 科学计算器 */
.keypad.scientific {
  height: 600rpx;
}

/* 行 */
.row {
  flex: 1;
  display: flex;
  gap: 15rpx;
}

/* 按键 */
.key {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  font-size: 32rpx;
  font-weight: 500;
  color: #333333;
  transition: all 0.2s ease;
  user-select: none;
}

.key:hover {
  background-color: #e0e0e0;
}

/* 运算符按键 */
.key.operator {
  background-color: #f0f7ff;
  color: #007AFF;
}

.key.operator:hover {
  background-color: #e0efff;
}

/* 等号按键 */
.key.equal {
  background-color: #007AFF;
  color: #ffffff;
  flex: 2;
}

.key.equal:hover {
  background-color: #0066cc;
}
/* calculator.wxss */
.calculator-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
  box-sizing: border-box;
}

.mode-toggle {
  display: flex;
  margin-bottom: 20rpx;
  border-radius: 10rpx;
  overflow: hidden;
  background-color: #e0e0e0;
}

.mode-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  font-size: 32rpx;
  color: #666;
}

.mode-btn.active {
  background-color: #4CAF50;
  color: white;
}

.display-area {
  background-color: #222;
  border-radius: 10rpx;
  padding: 30rpx 20rpx;
  margin-bottom: 20rpx;
  min-height: 180rpx;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.input-area, .result-area {
  display: flex;
  margin-bottom: 10rpx;
}

.input-label, .result-label {
  color: #aaa;
  font-size: 28rpx;
  margin-right: 10rpx;
}

.expression {
  color: #ddd;
  font-size: 36rpx;
  flex: 1;
  text-align: right;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.result {
  color: white;
  font-size: 48rpx;
  font-weight: bold;
  flex: 1;
  text-align: right;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.keypad {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.row {
  display: flex;
  flex: 1;
  margin-bottom: 10rpx;
}

.key {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  background-color: #fff;
  border-radius: 10rpx;
  margin-right: 10rpx;
  font-size: 40rpx;
  color: #333;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.1);
}

.key:last-child {
  margin-right: 0;
}

.key.zero {
  flex: 2;
  margin-right: 10rpx;
}

.key.operator {
  background-color: #ff9500;
  color: white;
}

.key.equal {
  background-color: #4CAF50;
  color: white;
}

.key.function {
  background-color: #2196F3;
  color: white;
  font-size: 36rpx;
}

.key:active {
  transform: scale(0.95);
  opacity: 0.9;
}

.scientific .key {
  font-size: 32rpx;
}

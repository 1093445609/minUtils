page {
  background-color: #000000;
  margin: 0;
  padding: 0;
  height: 100vh;
}

.calculator {
  display: flex;
  flex-direction: column;
  height: 100vh;
  padding: 0 12rpx 40rpx;
  box-sizing: border-box;
}

/* ===== 表达式显示区域 ===== */
.expression-area {
  padding: 20rpx 30rpx 10rpx;
  min-height: 80rpx;
  display: flex;
  align-items: flex-end;
  justify-content: flex-end;
  word-break: break-all;
}

.expression {
  font-size: 32rpx;
  color: #888888;
  min-height: 44rpx;
}

/* ===== 结果输出区域 ===== */
.result-area {
  padding: 10rpx 30rpx 20rpx;
  min-height: 120rpx;
  display: flex;
  align-items: flex-end;
  justify-content: flex-end;
  word-break: break-all;
  border-top: 1rpx solid #333333;
  border-bottom: 1rpx solid #333333;
  margin-bottom: 20rpx;
}

.result {
  font-size: 120rpx;
  font-weight: 300;
  color: #ffffff;
  transition: font-size 0.2s ease;
}

.result-small {
  font-size: 80rpx;
}

/* ===== 按钮区域 ===== */
.buttons {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.row {
  display: flex;
  gap: 20rpx;
}

/* ===== 按钮通用样式 ===== */
.btn {
  flex: 1;
  height: 140rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
  font-weight: 400;
  border: none;
  padding: 0;
  margin: 0;
  line-height: 140rpx;
  transition: opacity 0.15s ease, transform 0.1s ease;
}

.btn::after {
  border: none;
}

.btn:active {
  opacity: 0.7;
  transform: scale(0.95);
}

/* 数字按钮 */
.number {
  background-color: #333333;
  color: #ffffff;
}

/* 功能按钮 */
.func {
  background-color: #a5a5a5;
  color: #000000;
  font-size: 44rpx;
}

/* 运算符按钮 */
.operator {
  background-color: #ff9f0a;
  color: #ffffff;
  font-size: 58rpx;
}

.operator.active {
  background-color: #ffffff;
  color: #ff9f0a;
}

/* 等号按钮 */
.equal {
  background-color: #ff9f0a;
  color: #ffffff;
  font-size: 58rpx;
}

/* 0按钮占两格 */
.zero {
  flex: 2;
  border-radius: 70rpx;
  justify-content: flex-start;
  padding-left: 56rpx;
}
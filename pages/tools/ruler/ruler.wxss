.ruler-container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

/* 尺子显示区域 */
.ruler-area {
  flex: 1;
  display: flex;
  align-items: center;
  padding: 40rpx 0;
  background-color: #ffffff;
  margin: 20rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.1);
}

.ruler-scroll {
  width: 100%;
  height: 280rpx;
}

.ruler {
  position: relative;
  height: 200rpx;
  background-color: #ffffff;
  border: 2rpx solid #e0e0e0;
  border-radius: 8rpx;
  margin-top: 40rpx;
}

/* 刻度 */
.ruler-mark {
  position: absolute;
  bottom: 0;
  width: 2rpx;
  background-color: #333333;
}

/* 刻度文字 */
.ruler-text {
  position: absolute;
  bottom: -40rpx;
  left: 50%;
  transform: translateX(-50%);
  font-weight: 600;
  color: #333333;
  background-color: #ffffff;
  padding: 2rpx 8rpx;
  border-radius: 4rpx;
  white-space: nowrap;
}

/* 控制区域 */
.control-area {
  background-color: #ffffff;
  border-top-left-radius: 24rpx;
  border-top-right-radius: 24rpx;
  padding: 30rpx 20rpx;
  box-shadow: 0 -4rpx 8rpx rgba(0, 0, 0, 0.05);
}

/* 设置区域 */
.setting-section {
  margin-bottom: 30rpx;
}

.setting-label {
  display: block;
  font-size: 26rpx;
  color: #333333;
  margin-bottom: 15rpx;
  font-weight: 500;
}

/* 单位选择器 */
.unit-selector {
  display: flex;
  gap: 20rpx;
}

.unit-item {
  flex: 1;
  padding: 15rpx;
  text-align: center;
  border: 2rpx solid #e0e0e0;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #666666;
  cursor: pointer;
  transition: all 0.2s ease;
}

.unit-item.active {
  background-color: #007AFF;
  color: #ffffff;
  border-color: #007AFF;
}

/* 横屏按钮 */
.landscape-button {
  width: 100%;
  height: 80rpx;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 8rpx;
}

/* 说明 */
.instruction {
  padding: 20rpx;
  background-color: #f0f7ff;
  border-radius: 8rpx;
}

.instruction-text {
  font-size: 26rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 10rpx;
}

.instruction-detail {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.4;
}
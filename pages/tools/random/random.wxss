page {
  background-color: #f5f5f5;
  min-height: 100vh;
}

.random-container {
  padding: 20rpx;
}

.setting-section {
  background-color: #ffffff;
  border-radius: 8rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

.setting-label {
  display: block;
  font-size: 26rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 15rpx;
}

.number-input {
  width: 100%;
  padding: 15rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
}

.button-section {
  margin-bottom: 20rpx;
}

.generate-button {
  width: 100%;
  height: 80rpx;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 8rpx;
  background-color: #007AFF;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.result-section {
  background-color: #ffffff;
  border-radius: 8rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

.result-label {
  display: block;
  font-size: 26rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 15rpx;
}

.result-value {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #007AFF;
  text-align: center;
}

.history-section {
  background-color: #ffffff;
  border-radius: 8rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

.history-label {
  display: block;
  font-size: 26rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 15rpx;
}

.history-list {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
}

.history-item {
  padding: 10rpx 15rpx;
  background-color: #f0f7ff;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #007AFF;
}
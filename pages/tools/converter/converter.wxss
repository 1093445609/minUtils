.converter-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
}

/* 换算类型选择 */
.type-selector {
  display: flex;
  background-color: #ffffff;
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  border: 2rpx solid #e0e0e0;
}

.type-item {
  flex: 1;
  padding: 25rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 500;
  color: #000000;
  background-color: #f9f9f9;
  transition: all 0.3s ease;
  position: relative;
  border-right: 1rpx solid #e0e0e0;
}

.type-item:last-child {
  border-right: none;
}

.type-item:hover {
  background-color: #f0f7ff;
}

.type-item.active {
  background-color: #ffffff;
  color: #ff0000;
  box-shadow: inset 0 0 0 2rpx rgba(255, 0, 0, 0.3);
  font-weight: 600;
  transform: translateY(-2rpx);
}

/* 换算区域 */
.convert-section {
  background-color: #ffffff;
  border-radius: 8rpx;
  padding: 30rpx 20rpx;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

/* 输入部分 */
.input-section,
.output-section {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.value-input,
.value-output {
  flex: 1;
  padding: 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333333;
}

.value-output {
  background-color: #f9f9f9;
}

.unit-picker {
  width: 150rpx;
  padding: 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 8rpx;
  background-color: #f5f5f5;
}

.picker-text {
  font-size: 26rpx;
  color: #333333;
  text-align: center;
}

/* 转换按钮 */
.swap-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  height: 80rpx;
  background-color: #007AFF;
  border-radius: 50%;
  margin: 0 auto 30rpx;
  box-shadow: 0 2rpx 4rpx rgba(0, 122, 255, 0.3);
}

.swap-icon {
  font-size: 40rpx;
  color: #ffffff;
}
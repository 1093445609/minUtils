.colorpicker-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
}

/* 颜色预览 */
.color-preview {
  width: 100%;
  height: 200rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.1);
}

.color-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
  background-color: rgba(0, 0, 0, 0.3);
  padding: 10rpx 20rpx;
  border-radius: 8rpx;
}

/* 颜色选择器 */
.color-selector {
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

/* 色相滑块 */
.hue-slider {
  margin-bottom: 20rpx;
}

.hue-track {
  width: 100%;
  height: 10rpx;
  background: linear-gradient(to right, #ff0000, #ffff00, #00ff00, #00ffff, #0000ff, #ff00ff, #ff0000);
  border-radius: 5rpx;
  position: relative;
}

.hue-pointer {
  width: 20rpx;
  height: 20rpx;
  background-color: #ffffff;
  border: 2rpx solid #333333;
  border-radius: 50%;
  position: absolute;
  top: 50%;
  transform: translate(-50%, -50%);
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
}

/* 饱和度和亮度选择器 */
.sl-selector {
  width: 100%;
  height: 300rpx;
  position: relative;
  border-radius: 8rpx;
  overflow: hidden;
}

.sl-track {
  width: 100%;
  height: 100%;
  position: relative;
  background: linear-gradient(to right, rgba(255,255,255,0), rgba(255,255,255,1)), linear-gradient(to top, rgba(0,0,0,1), rgba(0,0,0,0));
}

.sl-pointer {
  width: 24rpx;
  height: 24rpx;
  background-color: #ffffff;
  border: 2rpx solid #333333;
  border-radius: 50%;
  position: absolute;
  transform: translate(-50%, -50%);
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
}

/* 颜色值输入 */
.color-inputs {
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

.input-group {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.input-label {
  font-size: 26rpx;
  font-weight: 500;
  color: #666666;
  width: 80rpx;
  flex-shrink: 0;
}

.color-input {
  flex: 1;
  padding: 15rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333333;
  font-family: monospace;
}

/* 常用颜色 */
.preset-colors {
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

.preset-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 15rpx;
}

.preset-grid {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 15rpx;
}

.preset-color {
  width: 100%;
  aspect-ratio: 1;
  border-radius: 8rpx;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
  cursor: pointer;
  transition: transform 0.2s ease;
}

.preset-color:hover {
  transform: scale(1.1);
}
.container { padding: 40rpx 30rpx; background: #f8f9fa; min-height: 100vh; box-sizing: border-box; }
.header { text-align: center; margin-bottom: 40rpx; }
.title { font-size: 42rpx; font-weight: 700; color: #111; }
.subtitle { font-size: 26rpx; color: #666; margin-top: 8rpx; }

.gender-switch { display: flex; align-items: center; justify-content: center; background: #fff; padding: 20rpx 30rpx; border-radius: 16rpx; margin-bottom: 24rpx; box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05); }
.label { font-size: 28rpx; margin-right: 20rpx; color: #444; }
.radio-item { display: flex; align-items: center; margin: 0 10rpx; }

.relation-selector { margin-bottom: 24rpx; }
.relation-row { display: flex; align-items: center; gap: 20rpx; }
.relation-picker { flex: 1; }
.picker-display { background: #fff; padding: 24rpx 30rpx; border-radius: 16rpx; font-size: 32rpx; box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05); text-align: center; }
.fixed-text { font-size: 32rpx; font-weight: 700; color: #333; }

.action-buttons { display: flex; gap: 20rpx; margin-bottom: 24rpx; }
.btn { flex: 1; border-radius: 16rpx; font-size: 32rpx; padding: 16rpx 0; }
.btn-calc { background: #1890ff; color: #fff; }
.btn-clear { background: #fff; color: #666; }
.btn::after { border: none; }

.error { background: #fff1f0; color: #cf1322; padding: 16rpx; border-radius: 12rpx; text-align: center; margin-bottom: 20rpx; font-size: 26rpx; }

.result { background: #fff; padding: 40rpx; border-radius: 20rpx; text-align: center; box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.1); margin-bottom: 24rpx; animation: pop 0.3s ease; }
@keyframes pop { from { opacity: 0; transform: scale(0.95); } to { opacity: 1; transform: scale(1); } }
.result-label { font-size: 28rpx; color: #666; }
.result-text { font-size: 64rpx; font-weight: 800; color: #1890ff; display: block; margin: 10rpx 0 20rpx; }
.meta { display: flex; justify-content: space-around; font-size: 24rpx; color: #888; border-top: 1rpx dashed #eee; padding-top: 16rpx; }

.history { background: #fff; padding: 24rpx; border-radius: 16rpx; }
.history-title { font-size: 28rpx; color: #555; margin-bottom: 12rpx; display: block; }
.history-list { display: flex; flex-wrap: wrap; gap: 12rpx; }
.history-item { background: #f0f2f5; padding: 8rpx 16rpx; border-radius: 16rpx; font-size: 24rpx; color: #555; }
.qrcode-container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

/* 输入区域 */
.input-section {
  background-color: #ffffff;
  margin: 20rpx;
  border-radius: 8rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

.text-input {
  width: 100%;
  height: 150rpx;
  padding: 15rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333333;
  resize: none;
}

/* 二维码显示区域 */
.qrcode-area {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #ffffff;
  margin: 0 20rpx 20rpx;
  border-radius: 8rpx;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
  padding: 40rpx;
}

.qrcode-wrapper {
  padding: 20rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
}

.qrcode-image {
  width: 300rpx;
  height: 300rpx;
}

.qrcode-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 300rpx;
  height: 300rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
}

.placeholder-text {
  font-size: 24rpx;
  color: #999999;
  text-align: center;
}

/* 控制区域 */
.control-area {
  background-color: #ffffff;
  border-top-left-radius: 24rpx;
  border-top-right-radius: 24rpx;
  padding: 30rpx 20rpx;
  box-shadow: 0 -4rpx 8rpx rgba(0, 0, 0, 0.05);
}

/* 设置区域 */
.setting-section {
  margin-bottom: 30rpx;
}

.setting-label {
  display: block;
  font-size: 26rpx;
  color: #333333;
  margin-bottom: 15rpx;
  font-weight: 500;
}

/* 滑块 */
.slider {
  width: 100%;
}

/* 按钮区域 */
.button-section {
  margin-bottom: 20rpx;
}

.generate-button,
.save-button {
  width: 100%;
  height: 80rpx;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 8rpx;
}
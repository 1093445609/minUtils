.imagecompress-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
}

/* 选择区域 */
.select-section {
  margin-bottom: 20rpx;
}

.select-button {
  width: 100%;
  height: 80rpx;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 8rpx;
}

/* 预览区域 */
.preview-section {
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 15rpx;
}

.preview-image {
  width: 100%;
  height: 300rpx;
  border-radius: 8rpx;
  margin-bottom: 15rpx;
  background-color: #f0f0f0;
}

.image-info {
  display: block;
  font-size: 24rpx;
  color: #666666;
  text-align: center;
}

/* 设置区域 */
.setting-section {
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

.setting-item {
  margin-bottom: 20rpx;
}

.setting-label {
  display: block;
  font-size: 26rpx;
  font-weight: 500;
  color: #666666;
  margin-bottom: 10rpx;
}

.slider {
  width: 100%;
  margin-bottom: 10rpx;
}

.setting-value {
  display: block;
  font-size: 24rpx;
  color: #007AFF;
  text-align: right;
}

.size-picker {
  width: 100%;
  padding: 15rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 8rpx;
  background-color: #f5f5f5;
}

.picker-text {
  font-size: 26rpx;
  color: #333333;
}

/* 按钮区域 */
.button-section {
  margin-bottom: 20rpx;
}

.compress-button,
.save-button {
  width: 100%;
  height: 80rpx;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 8rpx;
}

/* 结果区域 */
.result-section {
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

.compression-rate {
  display: block;
  font-size: 24rpx;
  color: #4CAF50;
  text-align: center;
  margin-top: 5rpx;
}
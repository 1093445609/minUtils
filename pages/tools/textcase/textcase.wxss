.textcase-container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
  padding: 20rpx;
}

/* 输入区域 */
.input-section {
  background-color: #ffffff;
  border-radius: 8rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

.text-input {
  width: 100%;
  height: 200rpx;
  padding: 15rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333333;
  resize: none;
}

/* 按钮区域 */
.button-section {
  display: flex;
  gap: 15rpx;
  margin-bottom: 20rpx;
}

.convert-button {
  flex: 1;
  height: 70rpx;
  font-size: 26rpx;
  font-weight: 500;
  border-radius: 8rpx;
}

/* 输出区域 */
.output-section {
  flex: 1;
  background-color: #ffffff;
  border-radius: 8rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

.output-label {
  display: block;
  font-size: 26rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 15rpx;
}

.text-output {
  width: 100%;
  height: 200rpx;
  padding: 15rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333333;
  resize: none;
  background-color: #f9f9f9;
}
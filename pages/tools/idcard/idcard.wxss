.idcard-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
}

/* 输入区域 */
.input-section {
  background-color: #ffffff;
  border-radius: 8rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

.idcard-input {
  width: 100%;
  padding: 15rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333333;
  letter-spacing: 2rpx;
}

/* 按钮区域 */
.button-section {
  margin-bottom: 20rpx;
}

.verify-button {
  width: 100%;
  height: 80rpx;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 8rpx;
}

/* 结果显示 */
.result-section {
  background-color: #ffffff;
  border-radius: 8rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

.result-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 15rpx;
}

.result-item {
  display: flex;
  margin-bottom: 10rpx;
  align-items: flex-start;
}

.result-label {
  font-size: 26rpx;
  font-weight: 500;
  color: #666666;
  width: 120rpx;
  flex-shrink: 0;
}

.result-value {
  font-size: 26rpx;
  color: #333333;
  flex: 1;
  word-break: break-all;
}

/* 校验状态 */
.status-section {
  background-color: #ffffff;
  border-radius: 8rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

.status-text {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
}
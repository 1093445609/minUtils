.container { min-height: 100vh; background: #0f0f0f; color: #f0f0f0; display: flex; flex-direction: column; align-items: center; padding: 50rpx 30rpx 120rpx; box-sizing: border-box; }

.mode-bar { display: flex; gap: 30rpx; margin-bottom: 50rpx; background: #222; padding: 8rpx; border-radius: 40rpx; }
.mode-btn { padding: 14rpx 32rpx; border-radius: 32rpx; font-size: 28rpx; color: #777; transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1); }
.mode-btn.active { background: #2563eb; color: #fff; font-weight: 600; box-shadow: 0 4rpx 12rpx rgba(37,99,235,0.4); }

.counter { text-align: center; margin-bottom: 80rpx; }
.count-num { font-size: 110rpx; font-weight: 800; background: linear-gradient(180deg, #fbbf24, #d97706); -webkit-background-clip: text; color: transparent; letter-spacing: -4rpx; }
.count-label { font-size: 30rpx; color: #888; margin-top: 8rpx; display: block; }

/* 木鱼主体 */
.fish-wrap { width: 360rpx; height: 360rpx; display: flex; align-items: center; justify-content: center; position: relative; }
.fish-body { width: 260rpx; height: 200rpx; background: linear-gradient(145deg, #8b5a2b, #5c3a1e); border-radius: 50% 50% 45% 45%; position: relative; box-shadow: inset -10rpx -10rpx 30rpx rgba(0,0,0,0.5), 0 15rpx 35rpx rgba(0,0,0,0.6); transition: transform 0.12s cubic-bezier(0.25, 0.46, 0.45, 0.94); transform: translate3d(0,0,0); }
.fish-body.pressed { transform: scale(0.93) translateY(8rpx); }

.fish-stick { position: absolute; top: 30rpx; right: 50rpx; width: 110rpx; height: 14rpx; background: linear-gradient(90deg, #a0522d, #cd853f); border-radius: 7rpx; transform-origin: right center; transform: rotate(-25deg); transition: transform 0.1s; box-shadow: 2rpx 3rpx 5rpx rgba(0,0,0,0.3); }
.fish-stick.striking { transform: rotate(5deg); }
.fish-stick::after { content: ''; position: absolute; left: -12rpx; top: -10rpx; width: 34rpx; height: 34rpx; background: radial-gradient(circle, #f5deb3, #d2b48c); border-radius: 50%; }

.fish-highlight { position: absolute; top: 20rpx; left: 40rpx; width: 60rpx; height: 20rpx; background: rgba(255,255,255,0.15); border-radius: 50%; filter: blur(4rpx); }

.ripple { position: absolute; width: 100%; height: 100%; border-radius: 50%; border: 2rpx solid rgba(255,255,255,0.2); opacity: 0; transform: scale(1); pointer-events: none; }
.ripple.animate { animation: rippleExpand 0.5s ease-out forwards; }
@keyframes rippleExpand { 0% { transform: scale(0.9); opacity: 0.8; } 100% { transform: scale(1.4); opacity: 0; } }

/* 浮动文字层：GPU加速，限制重绘 */
.float-layer { position: fixed; top: 25%; left: 0; right: 0; height: 200rpx; pointer-events: none; z-index: 50; }
.float-text { position: absolute; left: 50%; transform: translateX(-50%); font-size: 44rpx; font-weight: 700; color: #fbbf24; text-shadow: 0 2rpx 10rpx rgba(0,0,0,0.7); white-space: nowrap; will-change: transform, opacity; animation: floatUp 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94) var(--delay, 0ms) forwards; }
@keyframes floatUp { 0% { opacity: 1; transform: translateX(-50%) translateY(0) scale(1); } 60% { opacity: 1; transform: translateX(-50%) translateY(-60rpx) scale(1.05); } 100% { opacity: 0; transform: translateX(-50%) translateY(-140rpx) scale(0.8); } }

.controls { position: fixed; bottom: 60rpx; text-align: center; width: 100%; }
.tips { font-size: 22rpx; color: #555; margin-top: 16rpx; }
button { margin: 0 auto; } button::after { border: none; }

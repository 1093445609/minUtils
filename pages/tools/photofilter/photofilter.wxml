<view class="photofilter-container">
  <!-- 标题 -->
  <view class="title">
    <text class="title-text">照片调色</text>
  </view>
  
  <!-- 隐藏的canvas，用于保存图片 -->
  <canvas canvas-id="filterCanvas" style="width: 0; height: 0;"></canvas>

  <!-- 照片上传区域 -->
  <view class="upload-section">
    <view wx:if="{{!imagePath}}" class="upload-area" bindtap="chooseImage">
      <text class="upload-icon">📷</text>
      <text class="upload-text">点击上传照片</text>
    </view>
    <view wx:else class="preview-area">
      <image src="{{imagePath}}" mode="aspectFit" class="preview-image" style="filter: {{filterStyle}};"></image>
    </view>
  </view>

  <!-- 滤镜选择 -->
  <view wx:if="{{imagePath}}" class="filter-section">
    <text class="section-title">选择滤镜</text>
    <view class="filter-options">
      <view class="filter-option" bindtap="selectFilter" data-filter="none" class="{{selectedFilter === 'none' ? 'active' : ''}}">
        <text class="filter-name">原图</text>
      </view>
      <view class="filter-option" bindtap="selectFilter" data-filter="portrait" class="{{selectedFilter === 'portrait' ? 'active' : ''}}">
        <text class="filter-name">人像</text>
      </view>
      <view class="filter-option" bindtap="selectFilter" data-filter="fuji" class="{{selectedFilter === 'fuji' ? 'active' : ''}}">
        <text class="filter-name">富士NC</text>
      </view>
      <view class="filter-option" bindtap="selectFilter" data-filter="links" class="{{selectedFilter === 'links' ? 'active' : ''}}">
        <text class="filter-name">LINKS</text>
      </view>
    </view>
  </view>

  <!-- 滤镜强度调节 -->
  <view wx:if="{{imagePath && selectedFilter !== 'none'}}" class="intensity-section">
    <text class="section-title">滤镜强度: {{filterIntensity}}%</text>
    <slider min="0" max="100" value="{{filterIntensity}}" bindchange="onIntensityChange" class="intensity-slider" />
  </view>

  <!-- 操作按钮 -->
  <view wx:if="{{imagePath}}" class="action-section">
    <button class="action-button" bindtap="resetFilter" type="default">重置</button>
    <button class="action-button" bindtap="saveImage" type="primary">保存到本地</button>
  </view>

  <!-- 说明 -->
  <view class="instructions">
    <text class="instruction-text">使用说明:</text>
    <text class="instruction-detail">上传一张照片，选择喜欢的滤镜，调整强度，然后保存到本地</text>
  </view>
</view>
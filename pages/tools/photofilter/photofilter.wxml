<view class="page">
  <view class="canvas-box" bindtap="enterFullscreen">
    <canvas type="2d" id="cvs" class="canvas"></canvas>
    <view class="fullscreen-hint">点击查看全屏效果</view>
  </view>

  <view class="upload-btn" bindtap="chooseImage">
    <text>{{src ? '更换图片' : '选择图片'}}</text>
  </view>

  <!-- 全屏查看界面 -->
  <view wx:if="{{isFullscreen}}" class="fullscreen-container" bindtap="exitFullscreen">
    <canvas type="2d" id="fullscreenCanvas" class="fullscreen-canvas"></canvas>
    <view class="fullscreen-close">点击退出全屏</view>
  </view>

  <view wx:if="{{src}}" class="panel">
    <view class="row">
      <text>风格预设</text>
      <picker range="{{presetNames}}" value="selected" bindchange="onPresetChange">
        <view class="picker-box">{{presetNames[selected]}}</view>
      </picker>
    </view>

    <view class="row slider-line">
      <text>强度 {{intensity}}%</text>
      <slider value="{{intensity}}" min="0" max="100" bindchanging="onIntensityChange" activeColor="#66ccff" backgroundColor="#444"/>
    </view>

    <view class="sep">基础调整</view>
    <view class="row slider-line">
      <text>曝光</text>
      <slider value="{{exposure}}" min="-50" max="50" bindchanging="onExposure" activeColor="#ffffff" backgroundColor="#444"/>
    </view>
    <view class="row slider-line">
      <text>对比</text>
      <slider value="{{contrast}}" min="-50" max="100" bindchanging="onContrast" activeColor="#ffffff" backgroundColor="#444"/>
    </view>
    <view class="row slider-line">
      <text>饱和</text>
      <slider value="{{saturation}}" min="-50" max="100" bindchanging="onSaturation" activeColor="#ffffff" backgroundColor="#444"/>
    </view>
    <view class="row slider-line">
      <text>色温</text>
      <slider value="{{temp}}" min="-50" max="50" bindchanging="onTemp" activeColor="#ffb64e" backgroundColor="#444"/>
    </view>
    <view class="row slider-line">
      <text>色调</text>
      <slider value="{{tint}}" min="-30" max="30" bindchanging="onTint" activeColor="#ff77ff" backgroundColor="#444"/>
    </view>

    <view class="sep">风格微调</view>
    <view class="row slider-line">
      <text>褪色</text>
      <slider value="{{fade}}" min="0" max="60" bindchanging="onFade" activeColor="#aaaaaa" backgroundColor="#444"/>
    </view>
    <view class="row slider-line">
      <text>暗角</text>
      <slider value="{{vignette}}" min="0" max="80" bindchanging="onVignette" activeColor="#666" backgroundColor="#444"/>
    </view>

    <view class="btn-container">
      <button class="reset-btn" bindtap="resetFilters">重置</button>
      <button class="save-btn" bindtap="saveImage">保存到相册</button>
    </view>
  </view>
</view>
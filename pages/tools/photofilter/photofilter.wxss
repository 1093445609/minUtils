page{
  background:#121212;
  color:#fff;
}
.page{
  padding:20rpx;
}
.canvas-box{
  width:100%;
  height:520rpx;
  background:#1a1a1a;
  border-radius:20rpx;
  overflow:hidden;
  position: relative;
  cursor: pointer;
}
.canvas{
  width:100%;
  height:100%;
}
.fullscreen-hint{
  position: absolute;
  bottom: 20rpx;
  right: 20rpx;
  background: rgba(0, 0, 0, 0.6);
  color: #fff;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
  z-index: 1;
}
.fullscreen-container{
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  background: #000;
  z-index: 1000;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}
.fullscreen-canvas{
  width: 100vw;
  height: 100vh;
}
.fullscreen-close{
  position: absolute;
  top: 40rpx;
  right: 40rpx;
  background: rgba(0, 0, 0, 0.6);
  color: #fff;
  padding: 12rpx 24rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  z-index: 1001;
}
.upload-btn{
  margin:24rpx 0;
  background:#2a75ff;
  color:#fff;
  text-align:center;
  padding:24rpx;
  border-radius:16rpx;
}
.panel{
  margin-top:10rpx;
}
.row{
  display:flex;
  align-items:center;
  justify-content:space-between;
  margin-bottom:18rpx;
}
.slider-line{
  justify-content:flex-start;
}
slider{
  flex:1;
  margin:0 20rpx;
}
.picker-box{
  background:#222;
  padding:18rpx 26rpx;
  border-radius:12rpx;
  min-width:240rpx;
  text-align:center;
}
.sep{
  font-size:24rpx;
  color:#888;
  margin:30rpx 0 16rpx;
}
.btn-container{
  display:flex;
  gap:20rpx;
  margin-top:30rpx;
}
.reset-btn{
  flex:1;
  background:#444;
  color:#fff;
  border-radius:16rpx;
}
.save-btn{
  flex:1;
  background:#ff5555;
  color:#fff;
  border-radius:16rpx;
}
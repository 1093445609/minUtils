page{
  background:#121212;
  color:#fff;
}
.page{
  padding:20rpx;
}
.canvas-box{
  width:100%;
  height:520rpx;
  background:#1a1a1a;
  border-radius:20rpx;
  overflow:hidden;
}
.canvas{
  width:100%;
  height:100%;
}
.upload-btn{
  margin:24rpx 0;
  background:#2a75ff;
  color:#fff;
  text-align:center;
  padding:24rpx;
  border-radius:16rpx;
}
.panel{
  margin-top:10rpx;
}
.row{
  display:flex;
  align-items:center;
  justify-content:space-between;
  margin-bottom:18rpx;
}
.slider-line{
  justify-content:flex-start;
}
slider{
  flex:1;
  margin:0 20rpx;
}
.picker-box{
  background:#222;
  padding:18rpx 26rpx;
  border-radius:12rpx;
  min-width:240rpx;
  text-align:center;
}
.sep{
  font-size:24rpx;
  color:#888;
  margin:30rpx 0 16rpx;
}
.save-btn{
  background:#ff5555;
  color:#fff;
  border-radius:16rpx;
  margin-top:30rpx;
}
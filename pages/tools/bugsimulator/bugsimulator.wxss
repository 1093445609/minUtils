.bugsimulator-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
}

/* 标题 */
.title {
  text-align: center;
  margin-bottom: 30rpx;
}

.title-text {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
}

/* 虫子选择 */
.bug-selector {
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 25rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.selector-label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 20rpx;
}

.bug-options {
  display: flex;
  gap: 20rpx;
}

.bug-option {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 25rpx;
  background-color: #f9f9f9;
  border-radius: 8rpx;
  border: 2rpx solid #e0e0e0;
  transition: all 0.3s ease;
  cursor: pointer;
}

.bug-option.active {
  background-color: #ffffff;
  border-color: #007AFF;
  box-shadow: 0 2rpx 8rpx rgba(0, 122, 255, 0.2);
}

.bug-icon {
  font-size: 60rpx;
  margin-bottom: 10rpx;
}

.bug-name {
  font-size: 24rpx;
  color: #333333;
  font-weight: 500;
}

/* 控制区域 */
.control-section {
  margin-bottom: 30rpx;
}

.simulate-button {
  width: 100%;
  height: 80rpx;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 12rpx;
}

/* 模拟区域 */
.simulation-area {
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  overflow: hidden;
  position: relative;
}

.simulation-container {
  width: 100%;
  height: 100%;
  position: relative;
}

/* 蜘蛛模拟 */
.spider-simulation {
  position: relative;
  width: 100%;
  height: 100%;
  display: flex;
  justify-content: center;
  align-items: flex-start;
}

.spider-web {
  width: 2rpx;
  background-color: #e0e0e0;
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  transition: height 0.5s ease;
}

.spider {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  transition: bottom 0.5s ease;
}

/* 毛毛虫模拟 */
.caterpillar-simulation {
  position: relative;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
}

.caterpillar {
  position: absolute;
  transition: left 0.3s ease;
  animation: crawl 1s infinite alternate;
}

@keyframes crawl {
  0% {
    transform: translateY(0rpx);
  }
  100% {
    transform: translateY(10rpx);
  }
}

/* 说明 */
.instructions {
  background-color: #f0f7ff;
  border-radius: 8rpx;
  padding: 20rpx;
}

.instruction-text {
  font-size: 26rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 10rpx;
  display: block;
}

.instruction-detail {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.4;
}

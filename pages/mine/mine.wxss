.mine-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 20rpx;
}

/* 用户信息区域 */
.user-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
  background-color: #ffffff;
  margin-bottom: 20rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-bottom: 20rpx;
  background-color: #e0e0e0;
}

.avatar image {
  width: 100%;
  height: 100%;
}

.user-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

/* 功能列表 */
.function-list {
  background-color: #ffffff;
  border-radius: 16rpx;
  margin: 0 20rpx;
  overflow: hidden;
}

.function-item {
  display: flex;
  align-items: center;
  padding: 30rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.function-item:last-child {
  border-bottom: none;
}

.function-icon {
  width: 50rpx;
  height: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.function-icon .icon {
  font-size: 36rpx;
  color: #007AFF;
}

.function-text {
  flex: 1;
  font-size: 30rpx;
  color: #333333;
}

.function-arrow {
  width: 30rpx;
  height: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.function-arrow .arrow {
  font-size: 30rpx;
  color: #999999;
}

/* 版本信息 */
.version-info {
  text-align: center;
  margin-top: 40rpx;
  font-size: 24rpx;
  color: #999999;
}
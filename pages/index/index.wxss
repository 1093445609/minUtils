/**index.wxss**/
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

.scrollarea {
  flex: 1;
  overflow-y: auto;
}

.container {
  padding: 20rpx;
}

/* 搜索框 */
.search-box {
  margin-bottom: 20rpx;
}

.search-input {
  display: flex;
  align-items: center;
  background-color: #ffffff;
  border-radius: 8rpx;
  padding: 15rpx 20rpx;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

.search-icon {
  font-size: 28rpx;
  margin-right: 15rpx;
  color: #999999;
}

.search-input input {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

/* 工具分类 */
.tool-categories {
  margin-bottom: 20rpx;
}

.category-scroll {
  white-space: nowrap;
  padding-bottom: 10rpx;
}

.category-item {
  display: inline-block;
  padding: 10rpx 20rpx;
  margin-right: 15rpx;
  background-color: #ffffff;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #666666;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

.category-item.active {
  background-color: #007AFF;
  color: #ffffff;
}

/* 工具网格 */
.tool-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.tool-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 25rpx 10rpx;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
  transition: transform 0.2s ease;
}

.tool-item:hover {
  transform: translateY(-5rpx);
}

.tool-icon {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 15rpx;
  background-color: #f0f7ff;
  border-radius: 16rpx;
}

.tool-icon .icon {
  font-size: 40rpx;
  color: #007AFF;
}

.tool-name {
  font-size: 24rpx;
  color: #333333;
  text-align: center;
  line-height: 1.3;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 40rpx 0;
  color: #999999;
  font-size: 24rpx;
}

.load-more-text {
  display: block;
}

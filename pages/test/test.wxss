.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  background-color: #f0f0f0;
}

.count {
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 50rpx;
}

.tap-area {
  width: 200rpx;
  height: 200rpx;
  background-color: #007AFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 32rpx;
}
